# Copiar para .env e preencher. NAO commitar .env.

# URL base do ambiente-alvo (dev por padrao)
BASE_URL=https://seu-app.exemplo.com

# URL do IdP (login federado acontece aqui)
AUTH_URL=https://seu-idp.exemplo.com

# Locale padrao do AgFlow (aparece no path)
LOCALE=pt

# Timeouts em ms
NAVIGATION_TIMEOUT=30000
NETWORK_IDLE_TIMEOUT=5000

# Delay entre rotas no crawler (evita sobrecarregar dev)
RATE_LIMIT_MS=500

# Usuario que vai aparecer no frontmatter das notas (para auditoria)
CRAWLER_USER=qa-bot

# Escopo do crawl — URL de entrada e filtro de path
# Deixar CRAWL_SCOPE vazio para crawlar o site inteiro
CRAWL_START_URL=https://seu-app.exemplo.com/pt/flow/<flow-id>/board
CRAWL_SCOPE=<flow-id>
