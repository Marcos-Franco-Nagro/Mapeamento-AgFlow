{
  "name": "agflow-qa-mapper",
  "version": "0.1.0",
  "description": "Crawler Playwright + vault Obsidian para documentacao de QA do AgFlow",
  "private": true,
  "type": "module",
  "scripts": {
    "login": "tsx src/auth/login.ts",
    "crawl": "tsx src/crawler/index.ts",
    "navigate": "tsx src/navigator/index.ts",
    "navigate:modals": "tsx src/navigator/modal-index.ts",
    "navigate:activities": "tsx src/navigator/activity-index.ts",
    "navigate:activities:solicitacoes": "cross-env PHASE=1 tsx src/navigator/activity-index.ts",
    "navigate:activities:validacao": "cross-env PHASE=2 tsx src/navigator/activity-index.ts",
    "navigate:activities:pendencia": "cross-env PHASE=3 tsx src/navigator/activity-index.ts",
    "navigate:activities:alcadas": "cross-env PHASE=5 tsx src/navigator/activity-index.ts",
    "navigate:activities:analise": "cross-env PHASE=4 tsx src/navigator/activity-index.ts",
    "navigate:parecer": "tsx src/navigator/parecer-index.ts",
    "navigate:alcada": "tsx src/navigator/alcada-index.ts",
    "navigate:advance": "tsx src/navigator/advance-index.ts",
    "navigate:advance:solicitacoes": "cross-env PHASE=1 tsx src/navigator/advance-index.ts",
    "navigate:advance:validacao": "cross-env PHASE=2 tsx src/navigator/advance-index.ts",
    "navigate:advance:pendencia": "cross-env PHASE=3 tsx src/navigator/advance-index.ts",
    "navigate:advance:alcadas": "cross-env PHASE=5 tsx src/navigator/advance-index.ts",
    "navigate:advance:aprovado": "cross-env PHASE=6 tsx src/navigator/advance-index.ts",
    "navigate:advance:analise": "cross-env PHASE=4 tsx src/navigator/advance-index.ts",
    "navigate:cashflow:nova-area": "tsx src/navigator/cashflow-nova-area-index.ts",
    "navigate:cashflow:cadastrar-producao": "tsx src/navigator/cashflow-cadastrar-producao-index.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.0",
    "@types/node": "^20.14.0",
    "cross-env": "^10.1.0",
    "dotenv": "^16.0.0",
    "playwright": "^1.47.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
